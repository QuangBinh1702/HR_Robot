# HR Robot - Environment Variables
# Copy this to .env and customize

# Camera
CAMERA_INDEX=
CAMERA_WIDTH=
CAMERA_HEIGHT=
CAMERA_DEVICE=
CAMERA_BACKEND=auto
CAMERA_PIXEL_FORMAT=auto

# Face Detection
DETECTION_THRESHOLD=
NMS_THRESHOLD=

# Face Recognition
RECOGNITION_THRESHOLD=
GHOSTFACENET_RKNN_PATH=
GHOSTFACENET_MODEL_PATH=

# Face Liveness
USE_LIVENESS=true
LIVENESS_RKNN_PATH=models/anti_spoof.rknn
LIVENESS_ONNX_PATH=models/anti_spoof.onnx
LIVENESS_THRESHOLD=0.5
LIVENESS_CROP_SCALE=1.5

# Attendance
CHECKIN_COOLDOWN_SECONDS=
CHECKOUT_ABSENT_MINUTES=

# Room capacity
MAX_ROOM_CAPACITY=


DATABASE_URL=


# API
API_HOST=
API_PORT=
SECRET_KEY=

# RKNN NPU (set true on RK3588S board)
USE_NPU=false
NPU_CORE_MASK=1
SCRFD_NPU_CORE_MASK=1
ARCFACE_NPU_CORE_MASK=2
YOLO_NPU_CORE_MASK=4
LIVENESS_NPU_CORE_MASK=2
GHOSTFACENET_NPU_CORE_MASK=2
DEFAULT_EMBEDDING_MODEL_NAME=

ARCFACE_RKNN_PATH=
SCRFD_RKNN_PATH=

USE_PERSON_GATE=
USE_PIPELINE_V2=false
USE_RGA=true
RGA_LIB_PATH=librga.so
MAX_FACES_PER_FRAME=2
YOLOV8N_RKNN_PATH=
YOLO_PERSON_CONF_THRESHOLD=
YOLO_PERSON_MIN_BBOX_HEIGHT=
PERSON_TRIGGER_CONSECUTIVE_FRAMES=
PERSON_TRIGGER_MISS_FRAMES=
# Logging
LOG_LEVEL=
